  "source_hierarchy": [
    {
      "tool": "moneysmart_superannuation_calculator",
      "role": "Primary benchmark for accumulation and contribution-change cases",
      "url": "https://moneysmart.gov.au/how-super-works/superannuation-calculator"
    },
    {
      "tool": "moneysmart_account_based_pension_calculator",
      "role": "Primary benchmark for simple account-based pension drawdown",
      "url": "https://moneysmart.gov.au/retirement-income-sources/account-based-pension-calculator"
    },
    {
      "tool": "moneysmart_retirement_planner",
      "role": "Secondary benchmark for simple couple retirement cases after both people are retired",
      "url": "https://moneysmart.gov.au/plan-for-your-retirement/retirement-planner"
    },
    {
      "tool": "services_australia_age_pension_rules",
      "role": "Primary benchmark for first-year Age Pension means-test outcomes",
      "url": "https://www.servicesaustralia.gov.au/age-pension"
    }
  ],
  "global_alignment_rules": [
    "Use app as_of_date 2026-03-24.",
    "Use 1 January birth dates where practical to reduce app current-age versus Moneysmart June 30 age mismatch.",
    "Disable inheritance, TRIS, fixed employer override, carry-forward concessional caps, and outside-super drawdown unless a case explicitly requires them.",
    "Use benchmark overrides of 0% CPI inflation, 0% wage inflation or salary growth, and zero fees unless a case says otherwise.",
    "Use 6.0% investment return for accumulation and pension benchmark cases unless a case says otherwise.",
    "Only compare the fields listed in each case."
  ],
